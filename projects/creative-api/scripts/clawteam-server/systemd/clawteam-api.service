[Unit]
Description=CreativeGraph ClawTeam API Server
After=network.target memgraph.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/clawteam-server
ExecStart=/opt/clawteam-env/bin/uvicorn server:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
Environment=CLAWTEAM_DATA_DIR=/opt/clawteam-data

[Install]
WantedBy=multi-user.target
