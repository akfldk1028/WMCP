{
  "manifest_version": 3,
  "name": "BizScope AI",
  "version": "1.0.0",
  "description": "AI business strategy analysis — 20 frameworks, 9-dimension scorecard, multi-model ensemble",
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab"
  ],
  "host_permissions": [
    "https://bizscope-rho.vercel.app/*"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "settings/settings.html",
  "commands": {
    "quick-analyze": {
      "suggested_key": {
        "default": "Alt+Shift+B"
      },
      "description": "Quick analyze with BizScope AI"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
